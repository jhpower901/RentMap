# RentMap environment template. Copy to .env and fill in the secrets.
# .env is gitignored. Never commit real credentials.

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Postgres connection URL. The password segment must match the
# POSTGRES_PASSWORD value in db-stack/.env (they are independent files but
# the same credential). If you rotate the password, update BOTH .env files
# and re-up both compose stacks.
RENTMAP_DB_URL=postgresql://rentmap:CHANGE_ME_TO_MATCH_DB_STACK@rentmap-postgres:5432/rentmap

# ─────────────────────────────────────────────────────────────────────────────
# Self-login (multi-user)
# ─────────────────────────────────────────────────────────────────────────────
# Required for signup. New users must present this exact string at
# /api/auth/signup. Leave empty to disable signups (existing users can still
# log in, only new account creation is blocked). Treat as a secret — anyone
# with the code can create an account on this RentMap instance.
RENTMAP_SIGNUP_CODE=CHANGE_ME

# Session cookie Secure flag. auto (default) follows request scheme:
# HTTPS gets Secure cookies, plain-http LAN/local dev does not.
# Force 1 behind custom proxies that do not pass X-Forwarded-Proto.
# RENTMAP_SESSION_SECURE=auto

# ─────────────────────────────────────────────────────────────────────────────
# Discord notifications
# ─────────────────────────────────────────────────────────────────────────────
# Webhook URL the scheduler's webhook_worker POSTs to. Leave unset to disable
# delivery (events still queue up, ready to drain once the URL is set).
# Get a URL from Discord: Server Settings → Integrations → Webhooks → New.
# Treat as a secret — anyone with the URL can post to that channel as the bot.
RENTMAP_DISCORD_WEBHOOK_URL=

# Set to 1 to make reconcile mark every emitted event as already-sent so the
# webhook worker never picks it up. Recommended for the first 1–2 cron cycles
# after enabling reconcile (or after a major schema change) to confirm what
# the diff engine produces before opening the firehose to Discord.
# Default (unset / 0) = live delivery.
# RENTMAP_RECONCILE_DRY_RUN_WEBHOOKS=0

# ─────────────────────────────────────────────────────────────────────────────
# Optional crawl-area overrides
# ─────────────────────────────────────────────────────────────────────────────
# All have sensible defaults in docker-compose.yml; uncomment only to override.

# RENTMAP_AREA_NAME=아주대
# RENTMAP_CENTER_LAT=37.280062
# RENTMAP_CENTER_LNG=127.043688
# RENTMAP_RADIUS_KM=3.0
# RENTMAP_MAX_DEPOSIT=999999
# RENTMAP_MAX_RENT=999999

# Daangn region IDs (comma-separated). Find at daangn.com/kr/realty/?in=x-XXXX.
# RENTMAP_DAANGN_REGION_IDS=

# Naver Land URLs (pipe-separated — naver's ms= param contains commas).
# Leave empty to auto-generate a viewport grid from CENTER/RADIUS.
# RENTMAP_NAVER_URLS=

# Explicit Naver cortarNos (dong-level admin codes) to force-paginate. The
# default covers the 19 dongs our 3 km Ajou grid has been observed to land on.
# RENTMAP_NAVER_CORTARNOS=
